{
  "If Statement": {
    "prefix": "if",
    "body": [
      "if ${1:condition}",
      "    ${2:code}",
      "end"
    ],
    "description": "If statement"
  },
  "If-Elif-Else": {
    "prefix": "ifelse",
    "body": [
      "if ${1:condition}",
      "    ${2:code}",
      "elif ${3:condition}",
      "    ${4:code}",
      "else",
      "    ${5:code}",
      "end"
    ],
    "description": "If-elif-else statement"
  },
  "While Loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition}",
      "    ${2:code}",
      "end"
    ],
    "description": "While loop"
  },
  "For Loop": {
    "prefix": "for",
    "body": [
      "for ${1:i} in ${2:start} to ${3:end}",
      "    ${4:code}",
      "end"
    ],
    "description": "For loop"
  },
  "Function": {
    "prefix": "func",
    "body": [
      "func ${1:name}(${2:params})",
      "    ${3:code}",
      "end"
    ],
    "description": "Function definition"
  },
  "Class": {
    "prefix": "class",
    "body": [
      "class ${1:ClassName}",
      "    func init(self${2:, ${3:args}})",
      "        ${4:# Initialize}",
      "    end",
      "",
      "    func ${5:method}(self)",
      "        ${6:code}",
      "    end",
      "end"
    ],
    "description": "Class definition"
  },
  "Class with Inheritance": {
    "prefix": "classextends",
    "body": [
      "class ${1:ChildClass} extends ${2:ParentClass}",
      "    func init(self${3:, ${4:args}})",
      "        ${5:# Initialize}",
      "    end",
      "end"
    ],
    "description": "Class with inheritance"
  },
  "Try-Catch": {
    "prefix": "trycatch",
    "body": [
      "try",
      "    ${1:# risky code}",
      "catch ${2:error}",
      "    ${3:# handle error}",
      "end"
    ],
    "description": "Try-catch block"
  },
  "Print": {
    "prefix": "print",
    "body": [
      "print(${1:message})"
    ],
    "description": "Print statement"
  },
  "Input": {
    "prefix": "input",
    "body": [
      "${1:variable} = input(\"${2:prompt}\")"
    ],
    "description": "Input statement"
  },
  "Import": {
    "prefix": "import",
    "body": [
      "import \"${1:file.jts}\""
    ],
    "description": "Import statement"
  },
  "List": {
    "prefix": "list",
    "body": [
      "${1:name} = [${2:elements}]"
    ],
    "description": "List literal"
  },
  "Dictionary": {
    "prefix": "dict",
    "body": [
      "${1:name} = {\"${2:key}\": ${3:value}}"
    ],
    "description": "Dictionary literal"
  },
  "HTTP Server": {
    "prefix": "httpserver",
    "body": [
      "server = http_server(${1:8080})",
      "http_start(server)"
    ],
    "description": "HTTP server setup"
  }
}