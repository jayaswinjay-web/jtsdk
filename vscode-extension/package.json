{
  "name": "jts-go",
  "displayName": "JTS GO",
  "description": "Syntax highlighting and language support for JTS GO programming language",
  "version": "2.0.0",
  "publisher": "jaytechsolutions",
  "author": {
    "name": "Jay Tech Solutions"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers"
  ],
  "keywords": [
    "jts",
    "jts-go",
    "programming language",
    "bytecode",
    "virtual machine",
    "debugger"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jayaswinjay-web/jtsdk"
  },
  "contributes": {
    "languages": [
      {
        "id": "jts",
        "aliases": [
          "JTS GO",
          "jts"
        ],
        "extensions": [
          ".jts"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "jts",
        "scopeName": "source.jts",
        "path": "./syntaxes/jts.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "jts",
        "path": "./snippets/jts.json"
      }
    ],
    "debuggers": [
      {
        "type": "jts",
        "label": "JTS GO",
        "languages": ["jts"],
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the JTS GO program to debug",
                "default": "${workspaceFolder}/${fileBasename}"
              },
              "cwd": {
                "type": "string",
                "description": "Working directory",
                "default": "${workspaceFolder}"
              },
              "jtsPath": {
                "type": "string",
                "description": "Path to the JTS executable",
                "default": "jts"
              }
            }
          }
        },
        "configurationSnippets": [
          {
            "label": "JTS GO: Launch",
            "description": "Launch a JTS GO program for debugging",
            "body": {
              "type": "jts",
              "request": "launch",
              "name": "Debug JTS GO",
              "program": "${workspaceFolder}/${fileBasename}",
              "cwd": "${workspaceFolder}",
              "jtsPath": "jts"
            }
          }
        ],
        "initialConfigurations": [
          {
            "type": "jts",
            "request": "launch",
            "name": "Debug JTS GO",
            "program": "${workspaceFolder}/${fileBasename}",
            "cwd": "${workspaceFolder}",
            "jtsPath": "jts"
          }
        ]
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js"
}