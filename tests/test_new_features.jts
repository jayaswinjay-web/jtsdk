# Test break/continue
print("--- Break/Continue ---")
i = 0
while i < 10
    i = i + 1
    if i == 3
        continue
    end
    if i == 7
        break
    end
    print(i)
end

# Test elif
print("--- Elif ---")
x = 15
if x < 10
    print("small")
elif x < 20
    print("medium")
elif x < 30
    print("big")
else
    print("huge")
end

# Test += / -=
print("--- Compound Assignment ---")
a = 10
a += 5
print(a)
a -= 3
print(a)

# Test try/catch/throw
print("--- Try/Catch/Throw ---")
try
    throw "Something went wrong!"
catch e
    print("Caught: " + e)
end

# Test string methods
print("--- String Methods ---")
s = "hello world"
print(s.upper())
print(s.lower())
print(s.trim())
print(s.contains("world"))
print(s.replace("world", "JTS"))
print(s.substring(0, 5))
print(s.starts_with("hello"))
print(s.ends_with("world"))

# Test dictionary
print("--- Dictionary ---")
d = {"name": "JTS", "version": "2.0"}
print(d)
print(d["name"])

# Test list methods
print("--- List Methods ---")
lst = [3, 1, 2]
lst.sort()
print(lst)
lst.remove(2)
print(lst)
lst.pop()
print(lst)

# Test file I/O
print("--- File I/O ---")
write_file("test_output.txt", "Hello from JTS!")
content = read_file("test_output.txt")
print(content)

print("--- All tests passed! ---")