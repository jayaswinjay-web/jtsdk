# Arithmetic operations

a = 10
b = 3

print("a = " + a)
print("b = " + b)
print("a + b = " + (a + b))
print("a - b = " + (a - b))
print("a * b = " + (a * b))
print("a / b = " + (a / b))
print("a % b = " + (a % b))

# Operator precedence
print("(a + b) * 2 = " + ((a + b) * 2))
print("a + b * 2 = " + (a + b * 2))

# Unary minus
x = -5
print("x = " + x)
print("-x = " + (-x))
